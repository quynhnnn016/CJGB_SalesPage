# Feedback Page Environment Configuration
# Copy this file to .env and fill in the actual values

# N8N Workflow URLs
# These endpoints should be configured in your n8n instance
# The endpoints should accept POST requests with JSON payloads

# URL for finding orders (POST)
# Payload: { "action": "find_order", "order_code": "ORD-2024-001" }
# Response: { "found": true/false, "order": {...}, "error": null }
N8N_FEEDBACK_WORKFLOW_URL='https://quynhnnn23410.app.n8n.cloud/webhook-test/feedback-find-order'

# URL for submitting feedback (POST)
# Payload: { "action": "submit_feedback", "order_code": "...", "products": [...], "order_ratings": {...}, "metadata": {...} }
# Response: { "success": true/false, "message": "...", "data": {...} }
N8N_FEEDBACK_SUBMIT_URL='https://quynhnnn23410.app.n8n.cloud/webhook-test/feedback-submit'

# Optional: CORS headers if needed
# CORS_ORIGIN=https://yourdomain.com

# Optional: n8n authentication token (if required)
# N8N_API_KEY=your_api_key_here

# Optional: Enable development/mock mode
# DEV_MODE=false
